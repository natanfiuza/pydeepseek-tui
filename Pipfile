[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
# Interface TUI
textual = ">=0.82.0"

# Providers de IA
openai = ">=1.82.0"
anthropic = ">=0.49.0"

# HTTP assíncrono
httpx = ">=0.28.0"

# Criptografia de API keys
cryptography = ">=44.0.0"

# CLI
click = ">=8.1.0"

# Variáveis de ambiente
python-dotenv = ">=1.1.0"

# Parsing HTML (fetch_url tool)
beautifulsoup4 = ">=4.13.0"
lxml = ">=5.3.0"

# Web search sem API key
duckduckgo-search = ">=8.0.0"

# Operações Git
gitpython = ">=3.1.0"

# Markdown e syntax highlight
rich = ">=14.0.0"

[dev-packages]
# Testes
pytest = ">=8.3.0"
pytest-cov = ">=6.1.0"
pytest-asyncio = ">=0.26.0"
pytest-recording = ">=0.13.0"

# Qualidade de código
ruff = ">=0.11.0"
black = ">=25.1.0"
mypy = ">=1.15.0"

# Type stubs
types-beautifulsoup4 = "*"
types-requests = "*"

# Build e publicação
build = ">=1.2.0"
twine = ">=6.1.0"

[requires]
python_version = "3.11"

[scripts]
# Execução
run = "python -m pydeepseek_tui.main"

# Desenvolvimento
dev = "textual run --dev src/pydeepseek_tui/tui/app.py"

# Qualidade
lint = "ruff check src/ tests/"
format = "black src/ tests/"
typecheck = "mypy src/"

# Testes
test = "pytest tests/ -v"
test-cov = "pytest tests/ -v --cov=src/pydeepseek_tui --cov-report=term-missing --cov-report=html"

# Build e publicação
build-pkg = "python -m build"
publish-test = "twine upload --repository testpypi dist/*"
publish = "twine upload dist/*"
