# ============================================================
# pydeepseek-tui — Template de configuração
# ============================================================
#
# IMPORTANTE:
#   Este arquivo é apenas um TEMPLATE para referência.
#   O arquivo real fica em: ~/.deepseek-tui/.env
#   NUNCA versione o arquivo real com suas chaves de API.
#
# Como configurar:
#   Execute: pydeepseek-tui config
#   O assistente interativo irá criar e preencher o .env
#   automaticamente com as chaves criptografadas.
#
# As API keys são armazenadas CRIPTOGRAFADAS (Fernet + PBKDF2).
# A chave de criptografia é derivada automaticamente desta máquina.
# ============================================================

# ------------------------------------------------------------
# Provider ativo
# Valores aceitos: deepseek | openai | anthropic | ollama
# ------------------------------------------------------------
IA_PROVIDER=deepseek

# ------------------------------------------------------------
# DeepSeek
# Obtenha sua API key em: https://platform.deepseek.com/api_keys
# ------------------------------------------------------------
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
# ATENÇÃO: O valor abaixo deve ser gerado pelo 'pydeepseek-tui config'
# Não coloque sua API key em texto plano aqui!
DEEPSEEK_API_KEY_ENCRYPTED=

# ------------------------------------------------------------
# OpenAI (opcional — ative quando quiser usar GPT)
# Obtenha sua API key em: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY_ENCRYPTED=

# ------------------------------------------------------------
# Anthropic (opcional — ative quando quiser usar Claude)
# Obtenha sua API key em: https://console.anthropic.com/settings/keys
# ------------------------------------------------------------
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY_ENCRYPTED=

# ------------------------------------------------------------
# Ollama — modelos locais (sem API key necessária)
# Instale o Ollama em: https://ollama.com
# ------------------------------------------------------------
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------
# Adicionando novos providers no futuro
#
# Para adicionar um novo provider (ex: Google Gemini), basta:
#   1. Descomentar as linhas abaixo
#   2. Implementar GeminiProvider em src/providers/gemini.py
#   3. Registrar na ProviderFactory
#   4. Executar 'pydeepseek-tui config' para configurar a key
# ------------------------------------------------------------
# GEMINI_MODEL=gemini-pro-latest
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_API_KEY_ENCRYPTED=

# COHERE_MODEL=command-r-plus
# COHERE_API_KEY_ENCRYPTED=

# MISTRAL_MODEL=mistral-large-latest
# MISTRAL_API_KEY_ENCRYPTED=

# ------------------------------------------------------------
# Interface
# LANGUAGE: pt_BR | en_US
# AGENT_MODE: plan | agent | yolo
# THEME: dark | light
# ------------------------------------------------------------
LANGUAGE=pt_BR
AGENT_MODE=agent
THEME=dark

# ------------------------------------------------------------
# Limites e timeouts
# MAX_TOKENS: máximo de tokens na resposta
# CONTEXT_WINDOW: tamanho do contexto mantido em memória
# REQUEST_TIMEOUT: timeout em segundos para requisições à API
# ------------------------------------------------------------
MAX_TOKENS=8192
CONTEXT_WINDOW=65536
REQUEST_TIMEOUT=120
